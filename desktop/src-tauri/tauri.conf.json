{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Journey-Forge Local",
  "version": "0.1.0",
  "identifier": "com.journeyforge.local",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Journey-Forge Local",
        "width": 1200,
        "height": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "externalBin": ["binaries/jfl-server"]
  }
}
